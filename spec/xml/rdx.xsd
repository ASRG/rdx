<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           targetNamespace="https://asrg.io/ns/rdx"
           xmlns:rdx="https://asrg.io/ns/rdx"
           elementFormDefault="qualified" attributeFormDefault="unqualified"
           version="0.1.0">
  <xs:element name="riskSet" type="rdx:riskSetType"/>
  <xs:complexType name="riskSetType">
    <xs:sequence>
      <xs:element name="itemDefinition" type="rdx:itemDefinitionType"/>
      <xs:element name="assets" type="rdx:assetsType" minOccurs="0"/>
      <xs:element name="damageScenarios" type="rdx:damageScenariosType" minOccurs="0"/>
      <xs:element name="threatScenarios" type="rdx:threatScenariosType" minOccurs="0"/>
      <xs:element name="attackPaths" type="rdx:attackPathsType" minOccurs="0"/>
      <xs:element name="methods" type="rdx:methodsType" minOccurs="0"/>
      <xs:element name="attackFeasibilityRatings" type="rdx:afrsType" minOccurs="0"/>
      <xs:element name="impactRatings" type="rdx:irsType" minOccurs="0"/>
      <xs:element name="riskValues" type="rdx:riskValuesType" minOccurs="0"/>
      <xs:element name="controls" type="rdx:controlsType" minOccurs="0"/>
      <xs:element name="riskTreatmentDecisions" type="rdx:rtdsType" minOccurs="0"/>
      <xs:element name="systemComponents" type="rdx:systemComponentsType" minOccurs="0"/>
      <xs:element name="systemInterfaces" type="rdx:systemInterfacesType" minOccurs="0"/>
      <xs:element name="dataFlows" type="rdx:dataFlowsType" minOccurs="0"/>
      <xs:element name="relationships" type="rdx:relationshipsType" minOccurs="0"/>
    </xs:sequence>
    <xs:attribute name="schemaVersion" type="xs:string" use="required"/>
    <xs:attribute name="documentId" type="xs:string" use="optional"/>
  </xs:complexType>
  <xs:complexType name="itemDefinitionType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="title" type="xs:string"/>
      <xs:element name="boundary" type="xs:string" minOccurs="0"/>
      <xs:element name="functions" type="rdx:stringList" minOccurs="0"/>
      <xs:element name="architecture" type="xs:string" minOccurs="0"/>
      <xs:element name="interfaces" type="rdx:stringList" minOccurs="0"/>
      <xs:element name="environment" type="xs:string" minOccurs="0"/>
      <xs:element name="assumptions" type="rdx:stringList" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="assetsType">
    <xs:sequence>
      <xs:element name="asset" type="rdx:assetType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="assetType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="title" type="xs:string"/>
      <xs:element name="properties" type="rdx:ciaList" minOccurs="0"/>
      <xs:element name="linkedDamageScenarioIds" type="rdx:stringList" minOccurs="0"/>
      <xs:element name="linkedComponentIds" type="rdx:stringList" minOccurs="0"/>
      <xs:element name="linkedInterfaceIds" type="rdx:stringList" minOccurs="0"/>
      <xs:element name="externalIds" type="rdx:anyUriList" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="damageScenariosType">
    <xs:sequence>
      <xs:element name="damageScenario" type="rdx:damageScenarioType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="damageScenarioType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="title" type="xs:string"/>
      <xs:element name="description" type="xs:string" minOccurs="0"/>
      <xs:element name="impactedFunctions" type="rdx:stringList" minOccurs="0"/>
      <xs:element name="affectedRoadUsers" type="rdx:stringList" minOccurs="0"/>
      <xs:element name="references" type="rdx:anyUriList" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="threatScenariosType">
    <xs:sequence>
      <xs:element name="threatScenario" type="rdx:threatScenarioType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="threatScenarioType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="title" type="xs:string"/>
      <xs:element name="targetedAssetIds" type="rdx:stringList"/>
      <xs:element name="compromisedProperties" type="rdx:ciaList" minOccurs="0"/>
      <xs:element name="cause" type="xs:string" minOccurs="0"/>
      <xs:element name="targetedComponentIds" type="rdx:stringList" minOccurs="0"/>
      <xs:element name="targetedInterfaceIds" type="rdx:stringList" minOccurs="0"/>
      <xs:element name="references" type="rdx:anyUriList" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="attackPathsType">
    <xs:sequence>
      <xs:element name="attackPath" type="rdx:attackPathType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="attackPathType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="title" type="xs:string"/>
      <xs:element name="threatScenarioId" type="xs:string"/>
      <xs:element name="steps" type="rdx:stepsType" minOccurs="0"/>
      <xs:element name="references" type="rdx:anyUriList" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="methodsType">
    <xs:sequence>
      <xs:element name="method" type="rdx:methodType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="methodType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="name" type="xs:string"/>
      <xs:element name="version" type="xs:string"/>
      <xs:element name="factors" type="rdx:stringList" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="afrsType">
    <xs:sequence>
      <xs:element name="afr" type="rdx:afrType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="afrType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="attackPathId" type="xs:string"/>
      <xs:element name="methodId" type="xs:string"/>
      <xs:element name="score" type="xs:string"/>
      <xs:element name="band" type="xs:string" minOccurs="0"/>
      <xs:element name="rationale" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="irsType">
    <xs:sequence>
      <xs:element name="ir" type="rdx:irType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="irType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="damageScenarioId" type="xs:string"/>
      <xs:element name="methodId" type="xs:string"/>
      <xs:element name="score" type="xs:string"/>
      <xs:element name="rationale" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="riskValuesType">
    <xs:sequence>
      <xs:element name="riskValue" type="rdx:riskValueType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="riskValueType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="threatScenarioId" type="xs:string"/>
      <xs:element name="afrRef" type="xs:string"/>
      <xs:element name="impactRef" type="xs:string"/>
      <xs:element name="methodId" type="xs:string"/>
      <xs:element name="score" type="xs:string"/>
      <xs:element name="band" type="xs:string" minOccurs="0"/>
      <xs:element name="rationale" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="controlsType">
    <xs:sequence>
      <xs:element name="control" type="rdx:controlType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="controlType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="title" type="xs:string"/>
      <xs:element name="catalog" type="xs:string" minOccurs="0"/>
      <xs:element name="controlId" type="xs:string" minOccurs="0"/>
      <xs:element name="implementationStatus" type="xs:string" minOccurs="0"/>
      <xs:element name="references" type="rdx:anyUriList" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="rtdsType">
    <xs:sequence>
      <xs:element name="rtd" type="rdx:rtdType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="rtdType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="riskValueId" type="xs:string"/>
      <xs:element name="decision" type="xs:string"/>
      <xs:element name="controls" type="rdx:stringList" minOccurs="0"/>
      <xs:element name="justification" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="relationshipsType">
    <xs:sequence>
      <xs:element name="relationship" type="rdx:relationshipType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="relationshipType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="relationshipType">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:enumeration value="causes"/>
            <xs:enumeration value="mitigates"/>
            <xs:enumeration value="implements"/>
            <xs:enumeration value="assesses"/>
            <xs:enumeration value="contains"/>
            <xs:enumeration value="targets"/>
            <xs:enumeration value="threatens"/>
            <xs:enumeration value="protects"/>
            <xs:enumeration value="related_to"/>
            <xs:enumeration value="parent_of"/>
            <xs:enumeration value="child_of"/>
            <xs:enumeration value="connects_to"/>
            <xs:enumeration value="communicates_with"/>
            <xs:enumeration value="depends_on"/>
            <xs:enumeration value="exposes"/>
            <xs:enumeration value="inherits_from"/>
            <xs:enumeration value="deployed_on"/>
            <xs:enumeration value="runs_on"/>
            <xs:enumeration value="hosts"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="sourceRef" type="xs:string"/>
      <xs:element name="targetRef" type="xs:string"/>
      <xs:element name="confidence" minOccurs="0">
        <xs:simpleType>
          <xs:restriction base="xs:decimal">
            <xs:minInclusive value="0"/>
            <xs:maxInclusive value="1"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="justification" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <!-- architecture types -->
  <xs:complexType name="systemComponentsType">
    <xs:sequence>
      <xs:element name="systemComponent" type="rdx:systemComponentType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="systemComponentType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="title" type="xs:string"/>
      <xs:element name="componentType">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:enumeration value="system"/>
            <xs:enumeration value="subsystem"/>
            <xs:enumeration value="ecu"/>
            <xs:enumeration value="hardware"/>
            <xs:enumeration value="firmware"/>
            <xs:enumeration value="software"/>
            <xs:enumeration value="application"/>
            <xs:enumeration value="service"/>
            <xs:enumeration value="protocol"/>
            <xs:enumeration value="network"/>
            <xs:enumeration value="interface"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="description" type="xs:string" minOccurs="0"/>
      <xs:element name="vendor" type="xs:string" minOccurs="0"/>
      <xs:element name="version" type="xs:string" minOccurs="0"/>
      <xs:element name="parentComponentId" type="xs:string" minOccurs="0"/>
      <xs:element name="securityProperties" type="rdx:securityPropertiesType" minOccurs="0"/>
      <xs:element name="externalIds" type="rdx:anyUriList" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="securityPropertiesType">
    <xs:sequence>
      <xs:element name="trustLevel" minOccurs="0">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:enumeration value="trusted"/>
            <xs:enumeration value="semi-trusted"/>
            <xs:enumeration value="untrusted"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="criticalityLevel" minOccurs="0">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:enumeration value="safety-critical"/>
            <xs:enumeration value="mission-critical"/>
            <xs:enumeration value="business-critical"/>
            <xs:enumeration value="non-critical"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="attackSurface" type="rdx:stringList" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="systemInterfacesType">
    <xs:sequence>
      <xs:element name="systemInterface" type="rdx:systemInterfaceType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="systemInterfaceType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="title" type="xs:string"/>
      <xs:element name="interfaceType">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:enumeration value="physical"/>
            <xs:enumeration value="logical"/>
            <xs:enumeration value="network"/>
            <xs:enumeration value="api"/>
            <xs:enumeration value="protocol"/>
            <xs:enumeration value="bus"/>
            <xs:enumeration value="wireless"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="description" type="xs:string" minOccurs="0"/>
      <xs:element name="protocol" type="xs:string" minOccurs="0"/>
      <xs:element name="direction" minOccurs="0">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:enumeration value="input"/>
            <xs:enumeration value="output"/>
            <xs:enumeration value="bidirectional"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
      <xs:element name="dataTypes" type="rdx:stringList" minOccurs="0"/>
      <xs:element name="securityMechanisms" type="rdx:stringList" minOccurs="0"/>
      <xs:element name="componentId" type="xs:string" minOccurs="0"/>
      <xs:element name="externalIds" type="rdx:anyUriList" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="dataFlowsType">
    <xs:sequence>
      <xs:element name="dataFlow" type="rdx:dataFlowType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="dataFlowType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="title" type="xs:string"/>
      <xs:element name="description" type="xs:string" minOccurs="0"/>
      <xs:element name="sourceInterfaceId" type="xs:string"/>
      <xs:element name="targetInterfaceId" type="xs:string"/>
      <xs:element name="dataType" type="xs:string" minOccurs="0"/>
      <xs:element name="frequency" type="xs:string" minOccurs="0"/>
      <xs:element name="dataVolume" type="xs:string" minOccurs="0"/>
      <xs:element name="securityRequirements" type="rdx:securityRequirementsList" minOccurs="0"/>
      <xs:element name="trustBoundary" type="xs:boolean" minOccurs="0"/>
      <xs:element name="externalIds" type="rdx:anyUriList" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="stepsType">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:element name="value" type="xs:string"/>
      <xs:element name="attackStep" type="rdx:attackStepType"/>
    </xs:choice>
  </xs:complexType>
  <xs:complexType name="attackStepsType">
    <xs:sequence>
      <xs:element name="attackStep" type="rdx:attackStepType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="attackStepType">
    <xs:sequence>
      <xs:element name="id" type="xs:string"/>
      <xs:element name="description" type="xs:string"/>
      <xs:element name="targetComponentId" type="xs:string" minOccurs="0"/>
      <xs:element name="targetInterfaceId" type="xs:string" minOccurs="0"/>
      <xs:element name="technique" type="xs:string" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>
  <!-- helpers -->
  <xs:complexType name="ciaList">
    <xs:sequence><xs:element name="property" type="xs:string" minOccurs="0" maxOccurs="unbounded"/></xs:sequence>
  </xs:complexType>
  <xs:complexType name="stringList">
    <xs:sequence><xs:element name="value" type="xs:string" minOccurs="0" maxOccurs="unbounded"/></xs:sequence>
  </xs:complexType>
  <xs:complexType name="anyUriList">
    <xs:sequence><xs:element name="uri" type="xs:anyURI" minOccurs="0" maxOccurs="unbounded"/></xs:sequence>
  </xs:complexType>
  <xs:complexType name="securityRequirementsList">
    <xs:sequence>
      <xs:element name="requirement" minOccurs="0" maxOccurs="unbounded">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:enumeration value="confidentiality"/>
            <xs:enumeration value="integrity"/>
            <xs:enumeration value="availability"/>
            <xs:enumeration value="authenticity"/>
            <xs:enumeration value="authorization"/>
            <xs:enumeration value="non-repudiation"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>
</xs:schema>
