{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asrg.io/ns/rdx/schema/0.1.0/rdx.schema.json",
  "title": "Risk Data Exchange (RDX)",
  "type": "object",
  "required": [
    "schemaVersion",
    "documentId",
    "riskSet"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^0\\.1\\.0$"
    },
    "documentId": {
      "type": "string",
      "format": "uuid"
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "createdBy": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bomRefRef": {
      "type": "string"
    },
    "riskSet": {
      "type": "object",
      "required": [
        "itemDefinition"
      ],
      "properties": {
        "itemDefinition": {
          "type": "object",
          "required": [
            "id",
            "title"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "boundary": {
              "type": "string"
            },
            "functions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "architecture": {
              "type": "string"
            },
            "interfaces": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "environment": {
              "type": "string"
            },
            "assumptions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "countryOfOrigin": {
              "type": "string",
              "pattern": "^[A-Z]{2}$",
              "description": "ISO 3166-1 alpha-2 country code indicating the country of origin for this item"
            }
          },
          "additionalProperties": false
        },
        "assets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "properties": {
                "type": "array",
                "items": {
                  "enum": [
                    "confidentiality",
                    "integrity",
                    "availability"
                  ]
                }
              },
              "linkedDamageScenarioIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "externalIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "damageScenarios": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "impactedFunctions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "affectedRoadUsers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "threatScenarios": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "targetedAssetIds"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "targetedAssetIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "compromisedProperties": {
                "type": "array",
                "items": {
                  "enum": [
                    "confidentiality",
                    "integrity",
                    "availability"
                  ]
                }
              },
              "cause": {
                "type": "string"
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "attackPaths": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "threatScenarioId"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "threatScenarioId": {
                "type": "string"
              },
              "steps": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "methods": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "version"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "version": {
                "type": "string"
              },
              "factors": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "attackFeasibilityRatings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "attackPathId",
              "methodId",
              "score"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "attackPathId": {
                "type": "string"
              },
              "methodId": {
                "type": "string"
              },
              "inputFactors": {
                "type": "object",
                "additionalProperties": {
                  "type": [
                    "number",
                    "string",
                    "boolean"
                  ]
                }
              },
              "score": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "band": {
                "type": "string"
              },
              "rationale": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "impactRatings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "damageScenarioId",
              "methodId",
              "score"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "damageScenarioId": {
                "type": "string"
              },
              "methodId": {
                "type": "string"
              },
              "categories": {
                "type": "object",
                "additionalProperties": {
                  "type": [
                    "number",
                    "string"
                  ]
                }
              },
              "score": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "rationale": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "riskValues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "threatScenarioId",
              "afrRef",
              "impactRef",
              "methodId",
              "score"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "threatScenarioId": {
                "type": "string"
              },
              "afrRef": {
                "type": "string"
              },
              "impactRef": {
                "type": "string"
              },
              "methodId": {
                "type": "string"
              },
              "score": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "band": {
                "type": "string"
              },
              "rationale": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "controls": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "catalog": {
                "type": "string"
              },
              "controlId": {
                "type": "string"
              },
              "implementationStatus": {
                "type": "string"
              },
              "requiredCalLevel": {
                "type": "string",
                "enum": ["CAL1", "CAL2", "CAL3", "CAL4"]
              },
              "achievedCalLevel": {
                "type": "string",
                "enum": ["CAL1", "CAL2", "CAL3", "CAL4"]
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "riskTreatmentDecisions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "riskValueId",
              "decision"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "riskValueId": {
                "type": "string"
              },
              "decision": {
                "enum": [
                  "treat",
                  "avoid",
                  "accept",
                  "share"
                ]
              },
              "controls": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "justification": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "calAssuranceLevels": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "level",
              "objectives"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "level": {
                "type": "string",
                "enum": ["CAL1", "CAL2", "CAL3", "CAL4"]
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "objectives": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "assuranceActivities": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "calAssessments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "controlId",
              "targetCalLevel",
              "assessmentResult"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "controlId": {
                "type": "string"
              },
              "targetCalLevel": {
                "type": "string",
                "enum": ["CAL1", "CAL2", "CAL3", "CAL4"]
              },
              "assessmentResult": {
                "type": "string",
                "enum": ["sufficient", "insufficient", "pending"]
              },
              "achievedCalLevel": {
                "type": "string",
                "enum": ["CAL1", "CAL2", "CAL3", "CAL4"]
              },
              "evidenceRef": {
                "type": "string"
              },
              "assessmentDate": {
                "type": "string",
                "format": "date-time"
              },
              "assessor": {
                "type": "string"
              },
              "rationale": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "tafAssessments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "attackPathId",
              "methodId",
              "tafScore"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "attackPathId": {
                "type": "string"
              },
              "methodId": {
                "type": "string"
              },
              "targetContext": {
                "type": "object",
                "properties": {
                  "attackerProfile": {
                    "type": "string",
                    "enum": ["nation-state", "organized-crime", "hacktivist", "insider", "opportunist"]
                  },
                  "attackMotivation": {
                    "type": "string",
                    "enum": ["financial", "espionage", "disruption", "reputation", "other"]
                  },
                  "targetValue": {
                    "type": "string",
                    "enum": ["very-high", "high", "medium", "low"]
                  },
                  "accessRequirement": {
                    "type": "string",
                    "enum": ["remote", "adjacent", "physical", "insider"]
                  }
                },
                "additionalProperties": false
              },
              "tafScore": {
                "type": ["number", "string"]
              },
              "tafBand": {
                "type": "string",
                "enum": ["very-high", "high", "medium", "low", "very-low"]
              },
              "factorRatings": {
                "description": "Factor-specific ratings used in TAF calculation. Keys should align with or extend the method's factors array for custom assessment criteria.",
                "type": "object",
                "additionalProperties": {
                  "type": ["number", "string", "boolean"]
                }
              },
              "rationale": {
                "type": "string"
              },
              "assessmentDate": {
                "type": "string",
                "format": "date-time"
              }
            },
            "additionalProperties": false
          }
        },
        "relationships": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "relationshipType",
              "sourceRef",
              "targetRef"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "relationshipType": {
                "enum": [
                  "causes",
                  "mitigates",
                  "implements",
                  "assesses",
                  "contains",
                  "targets",
                  "threatens",
                  "protects",
                  "requires_cal",
                  "achieves_cal",
                  "related_to"
                ]
              },
              "sourceRef": {
                "type": "string"
              },
              "targetRef": {
                "type": "string"
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "justification": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}