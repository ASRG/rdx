{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asrg.io/ns/rdx/schema/0.1.0/rdx.schema.json",
  "title": "Risk Data Exchange (RDX)",
  "type": "object",
  "required": [
    "schemaVersion",
    "documentId",
    "riskSet"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^0\\.1\\.0$"
    },
    "documentId": {
      "type": "string",
      "format": "uuid"
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "createdBy": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bomRefRef": {
      "type": "string"
    },
    "riskSet": {
      "type": "object",
      "required": [
        "itemDefinition"
      ],
      "properties": {
        "itemDefinition": {
          "type": "object",
          "required": [
            "id",
            "title"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "boundary": {
              "type": "string"
            },
            "functions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "architecture": {
              "description": "System architecture description. Supports both a simple text description (legacy) or a structured representation with components and data flows.",
              "oneOf": [
                {
                  "type": "string",
                  "description": "Simple text description of the system architecture (legacy format)"
                },
                {
                  "type": "object",
                  "description": "Structured system architecture representation",
                  "properties": {
                    "description": {
                      "type": "string",
                      "description": "High-level description of the system architecture"
                    },
                    "components": {
                      "type": "array",
                      "description": "List of system components",
                      "items": {
                        "$ref": "#/$defs/ArchitectureComponent"
                      }
                    },
                    "dataFlows": {
                      "type": "array",
                      "description": "List of data flows between components",
                      "items": {
                        "$ref": "#/$defs/DataFlow"
                      }
                    },
                    "diagramUrl": {
                      "type": "string",
                      "description": "URL to an architecture diagram",
                      "format": "uri"
                    }
                  },
                  "additionalProperties": false
                }
              ]
            },
            "interfaces": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "environment": {
              "type": "string"
            },
            "assumptions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "countryOfOrigin": {
              "type": "string",
              "pattern": "^[A-Z]{2}$",
              "description": "ISO 3166-1 alpha-2 country code indicating the country of origin for this item"
            },
            "hashes": {
              "type": "array",
              "description": "Cryptographic hashes for the item definition document or binary",
              "items": {
                "$ref": "#/$defs/Hash"
              }
            }
          },
          "additionalProperties": true
        },
        "assets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "properties": {
                "type": "array",
                "items": {
                  "enum": [
                    "confidentiality",
                    "integrity",
                    "availability"
                  ]
                }
              },
              "linkedDamageScenarioIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "externalIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "hashes": {
                "type": "array",
                "description": "Cryptographic hashes for the asset (e.g., firmware binary, software component)",
                "items": {
                  "$ref": "#/$defs/Hash"
                }
              },
              "componentIds": {
                "type": "array",
                "description": "IDs of architecture components this asset is associated with",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "damageScenarios": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "impactedFunctions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "affectedRoadUsers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "threatScenarios": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "targetedAssetIds"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "targetedAssetIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "compromisedProperties": {
                "type": "array",
                "items": {
                  "enum": [
                    "confidentiality",
                    "integrity",
                    "availability"
                  ]
                }
              },
              "cause": {
                "type": "string"
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "componentIds": {
                "type": "array",
                "description": "IDs of architecture components relevant to this threat scenario",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "attackSteps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "attackFeasibilityRatingIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "controlIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "attackPaths": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "threatScenarioId"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "threatScenarioId": {
                "type": "string"
              },
              "stepIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "steps": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "deprecated": true
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "methods": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "version"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "version": {
                "type": "string"
              },
              "factors": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "riskThresholdMatrix": {
                "type": "array",
                "description": "Defines allowed risk treatment strategies per risk band for this methodology. Used to codify organizational risk acceptance policy that can be overlaid on risk data during interpretation.",
                "items": {
                  "type": "object",
                  "required": [
                    "band",
                    "allowedTreatments"
                  ],
                  "properties": {
                    "band": {
                      "type": "string",
                      "description": "The risk band label for this threshold entry (e.g., 'Very High', 'High', 'Medium', 'Low')"
                    },
                    "allowedTreatments": {
                      "type": "array",
                      "description": "The set of risk treatment strategies permitted for this risk band. Restricting to a subset enforces policy (e.g., High risk may only allow 'reduce' or 'avoid').",
                      "minItems": 1,
                      "items": {
                        "enum": [
                          "reduce",
                          "avoid",
                          "accept",
                          "share"
                        ]
                      }
                    },
                    "scoreRange": {
                      "type": "object",
                      "description": "Optional numeric score range that maps to this band",
                      "properties": {
                        "min": {
                          "type": ["number", "string"]
                        },
                        "max": {
                          "type": ["number", "string"]
                        }
                      },
                      "additionalProperties": false
                    },
                    "escalationRequired": {
                      "type": "boolean",
                      "description": "If true, risks in this band require management escalation before treatment"
                    },
                    "rationale": {
                      "type": "string",
                      "description": "Justification for the allowed treatments at this risk band"
                    },
                    "references": {
                      "type": "array",
                      "description": "References to policies, standards, or regulations that define this threshold",
                      "items": {
                        "type": "string"
                      }
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": true
          }
        },
        "attackFeasibilityRatings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "methodId",
              "score"
            ],
            "anyOf": [
              {
                "required": [
                  "attackPathId"
                ]
              },
              {
                "required": [
                  "attackStepId"
                ]
              }
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "attackPathId": {
                "type": "string"
              },
              "attackStepId": {
                "type": "string"
              },
              "methodId": {
                "type": "string"
              },
              "inputFactors": {
                "type": "object",
                "additionalProperties": {
                  "type": [
                    "number",
                    "string",
                    "boolean"
                  ]
                }
              },
              "score": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "band": {
                "type": "string"
              },
              "rationale": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "impactRatings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "damageScenarioId",
              "methodId",
              "score"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "damageScenarioId": {
                "type": "string"
              },
              "methodId": {
                "type": "string"
              },
              "categories": {
                "type": "object",
                "additionalProperties": {
                  "type": [
                    "number",
                    "string"
                  ]
                }
              },
              "score": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "rationale": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "riskValues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "threatScenarioId",
              "afrRef",
              "impactRef",
              "methodId",
              "score"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "threatScenarioId": {
                "type": "string"
              },
              "afrRef": {
                "type": "string"
              },
              "impactRef": {
                "type": "string"
              },
              "methodId": {
                "type": "string"
              },
              "score": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "band": {
                "type": "string"
              },
              "rationale": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "controls": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "catalog": {
                "type": "string"
              },
              "controlId": {
                "type": "string"
              },
              "implementationStatus": {
                "type": "string"
              },
              "requiredCalLevel": {
                "type": "string",
                "enum": [
                  "CAL1",
                  "CAL2",
                  "CAL3",
                  "CAL4"
                ]
              },
              "achievedCalLevel": {
                "type": "string",
                "enum": [
                  "CAL1",
                  "CAL2",
                  "CAL3",
                  "CAL4"
                ]
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "hashes": {
                "type": "array",
                "description": "Cryptographic hashes for the control document or specification",
                "items": {
                  "$ref": "#/$defs/Hash"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "riskTreatmentDecisions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "riskValueId",
              "decision"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "riskValueId": {
                "type": "string"
              },
              "decision": {
                "enum": [
                  "reduce",
                  "avoid",
                  "accept",
                  "share"
                ]
              },
              "controls": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "justification": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "calAssuranceLevels": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "level",
              "objectives"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "level": {
                "type": "string",
                "enum": [
                  "CAL1",
                  "CAL2",
                  "CAL3",
                  "CAL4"
                ]
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "objectives": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "assuranceActivities": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "calAssessments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "controlId",
              "targetCalLevel",
              "assessmentResult"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "controlId": {
                "type": "string"
              },
              "targetCalLevel": {
                "type": "string",
                "enum": [
                  "CAL1",
                  "CAL2",
                  "CAL3",
                  "CAL4"
                ]
              },
              "assessmentResult": {
                "type": "string",
                "enum": [
                  "sufficient",
                  "insufficient",
                  "pending"
                ]
              },
              "achievedCalLevel": {
                "type": "string",
                "enum": [
                  "CAL1",
                  "CAL2",
                  "CAL3",
                  "CAL4"
                ]
              },
              "evidenceRef": {
                "type": "string"
              },
              "assessmentDate": {
                "type": "string",
                "format": "date-time"
              },
              "assessor": {
                "type": "string"
              },
              "rationale": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "tafAssessments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "attackPathId",
              "methodId",
              "tafScore"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "attackPathId": {
                "type": "string"
              },
              "methodId": {
                "type": "string"
              },
              "targetContext": {
                "type": "object",
                "properties": {
                  "attackerProfile": {
                    "type": "string",
                    "enum": [
                      "nation-state",
                      "organized-crime",
                      "hacktivist",
                      "insider",
                      "opportunist"
                    ]
                  },
                  "attackMotivation": {
                    "type": "string",
                    "enum": [
                      "financial",
                      "espionage",
                      "disruption",
                      "reputation",
                      "other"
                    ]
                  },
                  "targetValue": {
                    "type": "string",
                    "enum": [
                      "very-high",
                      "high",
                      "medium",
                      "low"
                    ]
                  },
                  "accessRequirement": {
                    "type": "string",
                    "enum": [
                      "remote",
                      "adjacent",
                      "physical",
                      "insider"
                    ]
                  }
                },
                "additionalProperties": true
              },
              "tafScore": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "tafBand": {
                "type": "string",
                "enum": [
                  "very-high",
                  "high",
                  "medium",
                  "low",
                  "very-low"
                ]
              },
              "factorRatings": {
                "description": "Factor-specific ratings used in TAF calculation. Keys should align with or extend the method's factors array for custom assessment criteria.",
                "type": "object",
                "additionalProperties": {
                  "type": [
                    "number",
                    "string",
                    "boolean"
                  ]
                }
              },
              "rationale": {
                "type": "string"
              },
              "assessmentDate": {
                "type": "string",
                "format": "date-time"
              }
            },
            "additionalProperties": true
          }
        },
        "relationships": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "relationshipType",
              "sourceRef",
              "targetRef"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "relationshipType": {
                "enum": [
                  "causes",
                  "mitigates",
                  "implements",
                  "assesses",
                  "contains",
                  "targets",
                  "threatens",
                  "protects",
                  "requires_cal",
                  "achieves_cal",
                  "related_to"
                ]
              },
              "sourceRef": {
                "type": "string"
              },
              "targetRef": {
                "type": "string"
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "justification": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },d
  "additionalProperties": true
}
  "additionalProperties": false,
  "$defs": {
    "RiskLevel": {
      "type": "object",
      "description": "A named risk level (band/tier) within a rating methodology",
      "required": [
        "id",
        "label",
        "rank"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this risk level within the document"
        },
        "label": {
          "type": "string",
          "description": "Human-readable label for this level (e.g., 'Low', 'Medium', 'High', 'Very High')"
        },
        "rank": {
          "type": "integer",
          "minimum": 1,
          "description": "Ordinal rank indicating severity order, where 1 is the lowest/least severe level"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of what this risk level means in context"
        },
        "color": {
          "type": "string",
          "description": "Optional hex color code for visualization (e.g., '#FF0000' for red)",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "scoreRange": {
          "type": "object",
          "description": "Optional numeric score range that maps to this risk level",
          "properties": {
            "min": {
              "type": "number",
              "description": "Minimum score value (inclusive) for this level"
            },
            "max": {
              "type": "number",
              "description": "Maximum score value (inclusive) for this level"
            }
          },
          "additionalProperties": false
        },
        "treatmentGuidance": {
          "type": "string",
          "description": "Recommended risk treatment guidance for risks classified at this level"
        }
      },
      "additionalProperties": false
    },
    "Hash": {
      "type": "object",
      "description": "A cryptographic hash value for integrity verification",
      "required": [
        "alg",
        "content"
      ],
      "properties": {
        "alg": {
          "type": "string",
          "description": "The hash algorithm",
          "enum": [
            "MD5",
            "SHA-1",
            "SHA-256",
            "SHA-384",
            "SHA-512",
            "SHA3-256",
            "SHA3-384",
            "SHA3-512",
            "BLAKE2b-256",
            "BLAKE2b-384",
            "BLAKE2b-512",
            "BLAKE3"
          ]
        },
        "content": {
          "type": "string",
          "description": "The hash value as a hexadecimal string",
          "pattern": "^[0-9a-fA-F]+$"
        }
      },
      "additionalProperties": false
    },
    "ArchitectureComponent": {
      "type": "object",
      "description": "A component in the system architecture",
      "required": [
        "id",
        "name",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this component"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name of the component"
        },
        "type": {
          "type": "string",
          "description": "Component type classification",
          "enum": [
            "ecu",
            "sensor",
            "actuator",
            "gateway",
            "network",
            "external-system",
            "cloud-service",
            "mobile-app",
            "ota-server",
            "diagnostic-tool",
            "other"
          ]
        },
        "parentId": {
          "type": "string",
          "description": "ID of the parent component (for hierarchical architectures)"
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the component and its role"
        },
        "trustBoundary": {
          "type": "string",
          "description": "The trust boundary or security zone this component belongs to"
        },
        "externalIds": {
          "type": "array",
          "description": "External identifiers (e.g., from other tools or standards)",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "DataFlow": {
      "type": "object",
      "description": "A data flow between architecture components",
      "required": [
        "id",
        "fromComponentId",
        "toComponentId"
      ],
      "properties": {
