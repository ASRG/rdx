{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asrg.io/ns/rdx/schema/0.1.0/rdx.schema.json",
  "title": "Risk Data Exchange (RDX)",
  "type": "object",
  "required": [
    "schemaVersion",
    "documentId",
    "riskSet"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^0\\.1\\.0$"
    },
    "documentId": {
      "type": "string",
      "format": "uuid"
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "createdBy": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bomRefRef": {
      "type": "string"
    },
    "riskSet": {
      "type": "object",
      "required": [
        "itemDefinition"
      ],
      "properties": {
        "itemDefinition": {
          "type": "object",
          "required": [
            "id",
            "title"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "boundary": {
              "type": "string"
            },
            "functions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "architecture": {
              "description": "System architecture description. Supports both a simple text description (legacy) or a structured representation with components and data flows.",
              "oneOf": [
                {
                  "type": "string",
                  "description": "Simple text description of the system architecture (legacy format)"
                },
                {
                  "type": "object",
                  "description": "Structured system architecture representation",
                  "properties": {
                    "description": {
                      "type": "string",
                      "description": "High-level description of the system architecture"
                    },
                    "components": {
                      "type": "array",
                      "description": "List of system components",
                      "items": {
                        "$ref": "#/$defs/ArchitectureComponent"
                      }
                    },
                    "dataFlows": {
                      "type": "array",
                      "description": "List of data flows between components",
                      "items": {
                        "$ref": "#/$defs/DataFlow"
                      }
                    },
                    "diagramUrl": {
                      "type": "string",
                      "description": "URL to an architecture diagram",
                      "format": "uri"
                    }
                  },
                  "additionalProperties": false
                }
              ]
            },
            "interfaces": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "environment": {
              "type": "string"
            },
            "assumptions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "countryOfOrigin": {
              "type": "string",
              "pattern": "^[A-Z]{2}$",
              "description": "ISO 3166-1 alpha-2 country code indicating the country of origin for this item"
            },
            "hashes": {
              "type": "array",
              "description": "Cryptographic hashes for the item definition document or binary",
              "items": {
                "$ref": "#/$defs/Hash"
              }
            }
          },
          "additionalProperties": true
        },
        "assets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "properties": {
                "type": "array",
                "items": {
                  "enum": [
                    "confidentiality",
                    "integrity",
                    "availability"
                  ]
                }
              },
              "linkedDamageScenarioIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "externalIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "hashes": {
                "type": "array",
                "description": "Cryptographic hashes for the asset (e.g., firmware binary, software component)",
                "items": {
                  "$ref": "#/$defs/Hash"
                }
              },
              "componentIds": {
                "type": "array",
                "description": "IDs of architecture components this asset is associated with",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "damageScenarios": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "impactedFunctions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "affectedRoadUsers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "threatScenarios": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "targetedAssetIds"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "targetedAssetIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "compromisedProperties": {
                "type": "array",
                "items": {
                  "enum": [
                    "confidentiality",
                    "integrity",
                    "availability"
                  ]
                }
              },
              "cause": {
                "type": "string"
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "componentIds": {
                "type": "array",
                "description": "IDs of architecture components relevant to this threat scenario",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "attackSteps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "attackFeasibilityRatingIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "controlIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "attackPaths": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "threatScenarioId"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "threatScenarioId": {
                "type": "string"
              },
              "stepIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "steps": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "deprecated": true
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "methods": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "version"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "version": {
                "type": "string"
              },
              "factors": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "attackFeasibilityRatings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "methodId",
              "score"
            ],
            "anyOf": [
              {
                "required": [
                  "attackPathId"
                ]
              },
              {
                "required": [
                  "attackStepId"
                ]
              }
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "attackPathId": {
                "type": "string"
              },
              "attackStepId": {
                "type": "string"
              },
              "methodId": {
                "type": "string"
              },
              "inputFactors": {
                "type": "object",
                "additionalProperties": {
                  "type": [
                    "number",
                    "string",
                    "boolean"
                  ]
                }
              },
              "score": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "band": {
                "type": "string"
              },
              "rationale": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "impactRatings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "damageScenarioId",
              "methodId",
              "score"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "damageScenarioId": {
                "type": "string"
              },
              "methodId": {
                "type": "string"
              },
              "categories": {
                "type": "object",
                "additionalProperties": {
                  "type": [
                    "number",
                    "string"
                  ]
                }
              },
              "score": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "rationale": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "riskValues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "threatScenarioId",
              "afrRef",
              "impactRef",
              "methodId",
              "score"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "threatScenarioId": {
                "type": "string"
              },
              "afrRef": {
                "type": "string"
              },
              "impactRef": {
                "type": "string"
              },
              "methodId": {
                "type": "string"
              },
              "score": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "band": {
                "type": "string"
              },
              "rationale": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "controls": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "catalog": {
                "type": "string"
              },
              "controlId": {
                "type": "string"
              },
              "implementationStatus": {
                "type": "string"
              },
              "requiredCalLevel": {
                "type": "string",
                "enum": [
                  "CAL1",
                  "CAL2",
                  "CAL3",
                  "CAL4"
                ]
              },
              "achievedCalLevel": {
                "type": "string",
                "enum": [
                  "CAL1",
                  "CAL2",
                  "CAL3",
                  "CAL4"
                ]
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "hashes": {
                "type": "array",
                "description": "Cryptographic hashes for the control document or specification",
                "items": {
                  "$ref": "#/$defs/Hash"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "riskTreatmentDecisions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "riskValueId",
              "decision"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "riskValueId": {
                "type": "string"
              },
              "decision": {
                "enum": [
                  "treat",
                  "avoid",
                  "accept",
                  "share"
                ]
              },
              "controls": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "justification": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "calAssuranceLevels": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "level",
              "objectives"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "level": {
                "type": "string",
                "enum": [
                  "CAL1",
                  "CAL2",
                  "CAL3",
                  "CAL4"
                ]
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "objectives": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "assuranceActivities": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "calAssessments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "controlId",
              "targetCalLevel",
              "assessmentResult"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "controlId": {
                "type": "string"
              },
              "targetCalLevel": {
                "type": "string",
                "enum": [
                  "CAL1",
                  "CAL2",
                  "CAL3",
                  "CAL4"
                ]
              },
              "assessmentResult": {
                "type": "string",
                "enum": [
                  "sufficient",
                  "insufficient",
                  "pending"
                ]
              },
              "achievedCalLevel": {
                "type": "string",
                "enum": [
                  "CAL1",
                  "CAL2",
                  "CAL3",
                  "CAL4"
                ]
              },
              "evidenceRef": {
                "type": "string"
              },
              "assessmentDate": {
                "type": "string",
                "format": "date-time"
              },
              "assessor": {
                "type": "string"
              },
              "rationale": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "tafAssessments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "attackPathId",
              "methodId",
              "tafScore"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "attackPathId": {
                "type": "string"
              },
              "methodId": {
                "type": "string"
              },
              "targetContext": {
                "type": "object",
                "properties": {
                  "attackerProfile": {
                    "type": "string",
                    "enum": [
                      "nation-state",
                      "organized-crime",
                      "hacktivist",
                      "insider",
                      "opportunist"
                    ]
                  },
                  "attackMotivation": {
                    "type": "string",
                    "enum": [
                      "financial",
                      "espionage",
                      "disruption",
                      "reputation",
                      "other"
                    ]
                  },
                  "targetValue": {
                    "type": "string",
                    "enum": [
                      "very-high",
                      "high",
                      "medium",
                      "low"
                    ]
                  },
                  "accessRequirement": {
                    "type": "string",
                    "enum": [
                      "remote",
                      "adjacent",
                      "physical",
                      "insider"
                    ]
                  }
                },
                "additionalProperties": true
              },
              "tafScore": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "tafBand": {
                "type": "string",
                "enum": [
                  "very-high",
                  "high",
                  "medium",
                  "low",
                  "very-low"
                ]
              },
              "factorRatings": {
                "description": "Factor-specific ratings used in TAF calculation. Keys should align with or extend the method's factors array for custom assessment criteria.",
                "type": "object",
                "additionalProperties": {
                  "type": [
                    "number",
                    "string",
                    "boolean"
                  ]
                }
              },
              "rationale": {
                "type": "string"
              },
              "assessmentDate": {
                "type": "string",
                "format": "date-time"
              }
            },
            "additionalProperties": true
          }
        },
        "relationships": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "relationshipType",
              "sourceRef",
              "targetRef"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "relationshipType": {
                "enum": [
                  "causes",
                  "mitigates",
                  "implements",
                  "assesses",
                  "contains",
                  "targets",
                  "threatens",
                  "protects",
                  "requires_cal",
                  "achieves_cal",
                  "related_to",
                  "derived_from",
                  "addresses",
                  "satisfies",
                  "supports"
                ]
              },
              "sourceRef": {
                "type": "string"
              },
              "targetRef": {
                "type": "string"
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "justification": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "cybersecurityGoals": {
          "description": "Cybersecurity goals derived from risk assessment (ISO/SAE 21434 Clause 9.3, WP-09-02). Goals define the high-level security objectives the item must achieve.",
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "linkedThreatScenarioIds": {
                "type": "array",
                "description": "Threat scenarios that motivated this cybersecurity goal",
                "items": {
                  "type": "string"
                }
              },
              "linkedRiskValueIds": {
                "type": "array",
                "description": "Risk values that are addressed by this cybersecurity goal",
                "items": {
                  "type": "string"
                }
              },
              "linkedDamageScenarioIds": {
                "type": "array",
                "description": "Damage scenarios prevented by achieving this cybersecurity goal",
                "items": {
                  "type": "string"
                }
              },
              "goalType": {
                "type": "string",
                "description": "The primary CIA or other security property this goal targets",
                "enum": [
                  "confidentiality",
                  "integrity",
                  "availability",
                  "authenticity",
                  "non-repudiation",
                  "general"
                ]
              },
              "acceptanceCriteria": {
                "type": "string",
                "description": "Verifiable criteria that determine when this goal is achieved"
              },
              "status": {
                "type": "string",
                "enum": [
                  "proposed",
                  "approved",
                  "verified",
                  "deprecated"
                ]
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "cybersecurityClaims": {
          "description": "Cybersecurity claims asserting that security properties have been achieved. Claims support cybersecurity goals and may reference evidence.",
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "claim"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "claim": {
                "type": "string",
                "description": "The assertion being made about a cybersecurity property"
              },
              "linkedGoalIds": {
                "type": "array",
                "description": "Cybersecurity goals this claim supports",
                "items": {
                  "type": "string"
                }
              },
              "linkedControlIds": {
                "type": "array",
                "description": "Controls providing evidence for this claim",
                "items": {
                  "type": "string"
                }
              },
              "linkedRequirementIds": {
                "type": "array",
                "description": "Cybersecurity requirements this claim supports",
                "items": {
                  "type": "string"
                }
              },
              "evidenceRef": {
                "type": "string",
                "description": "Reference to evidence substantiating this claim"
              },
              "status": {
                "type": "string",
                "enum": [
                  "asserted",
                  "verified",
                  "rejected",
                  "pending"
                ]
              },
              "rationale": {
                "type": "string"
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "cybersecurityRequirements": {
          "description": "Cybersecurity requirements derived from cybersecurity goals (ISO/SAE 21434 Clause 9.4, WP-09-03). Requirements specify what the item must do to achieve its cybersecurity goals.",
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "cybersecurityGoalId": {
                "type": "string",
                "description": "The cybersecurity goal this requirement derives from"
              },
              "requirementType": {
                "type": "string",
                "description": "Classification of the requirement",
                "enum": [
                  "functional",
                  "non-functional",
                  "constraint",
                  "interface",
                  "process"
                ]
              },
              "allocatedTo": {
                "type": "string",
                "description": "Component, subsystem, or layer to which this requirement is allocated"
              },
              "verificationMethod": {
                "type": "string",
                "description": "How conformance to this requirement will be verified",
                "enum": [
                  "test",
                  "analysis",
                  "inspection",
                  "demonstration",
                  "review"
                ]
              },
              "status": {
                "type": "string",
                "enum": [
                  "proposed",
                  "approved",
                  "implemented",
                  "verified",
                  "deprecated"
                ]
              },
              "linkedControlIds": {
                "type": "array",
                "description": "Controls implementing this requirement",
                "items": {
                  "type": "string"
                }
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "cybersecurityConcept": {
          "description": "Cybersecurity concept entries describing the high-level approach to achieving cybersecurity goals (ISO/SAE 21434 Clause 9.4, WP-09-03). Each entry captures a design decision or architectural choice.",
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "description": {
