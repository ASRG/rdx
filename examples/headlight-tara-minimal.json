  "riskSet": {
    "itemDefinition": {
      "id": "ITEM-HEADLIGHT-001",
      "title": "Adaptive Front-lighting System (AFS)",
      "boundary": "AFS headlight ECU including CAN interface, LED matrix control, stepper motor drivers, and UDS diagnostic services",
      "functions": [
        "Adaptive beam control",
        "Glare-free high beam",
        "Dynamic leveling",
        "Diagnostic communication"
      ],
      "architecture": {
        "description": "AFS ECU connected to body CAN bus for receiving control commands and speed data; diagnostics routed through central gateway and OBD-II port",
        "components": [
          {
            "id": "comp-afs-ecu",
            "name": "AFS ECU",
            "type": "ecu"
          },
          {
            "id": "comp-bcm",
            "name": "Body Control Module",
            "type": "ecu"
          },
          {
            "id": "comp-cgw",
            "name": "Central Gateway",
            "type": "gateway"
          },
          {
            "id": "comp-speed-sensor",
            "name": "Vehicle Speed Sensor",
            "type": "sensor"
          },
          {
            "id": "comp-body-can",
            "name": "Body CAN Bus",
            "type": "network"
          },
          {
            "id": "comp-obd-port",
            "name": "OBD-II Diagnostic Port",
            "type": "diagnostic-tool"
          }
        ],
        "dataFlows": [
          {
            "id": "df-speed-to-afs",
            "name": "Vehicle Speed Signal",
            "fromComponentId": "comp-speed-sensor",
            "toComponentId": "comp-afs-ecu",
            "protocol": "CAN"
          },
          {
            "id": "df-bcm-to-afs",
            "name": "Light Control Commands",
            "fromComponentId": "comp-bcm",
            "toComponentId": "comp-afs-ecu",
            "protocol": "CAN"
          },
          {
            "id": "df-obd-to-cgw",
            "name": "Diagnostic Requests",
            "fromComponentId": "comp-obd-port",
            "toComponentId": "comp-cgw",
            "protocol": "UDS"
          },
          {
            "id": "df-cgw-to-afs",
            "name": "Routed Diagnostic Messages",
            "fromComponentId": "comp-cgw",
            "toComponentId": "comp-afs-ecu",
            "protocol": "UDS"
          }
        ]
      }
    },
    "assets": [
      {
        "id": "ASSET-LIGHT-CTRL",
        "title": "Light Control Commands",
        "properties": ["integrity", "availability"],
        "linkedDamageScenarioIds": ["DS-SAF-BLIND", "DS-SAF-GLARE"],
        "componentIds": ["comp-afs-ecu", "comp-body-can"]
      },
      {
        "id": "ASSET-VEH-SPEED",
        "title": "Vehicle Speed Data",
        "properties": ["integrity", "confidentiality"],
        "linkedDamageScenarioIds": ["DS-PRIV-TRACK"],
        "componentIds": ["comp-speed-sensor", "comp-body-can"]
      },
      {
        "id": "ASSET-DIAG-DATA",
        "title": "Diagnostic Information",
        "properties": ["confidentiality", "integrity"],
        "linkedDamageScenarioIds": ["DS-PRIV-VEH-ID"],
        "componentIds": ["comp-obd-port", "comp-afs-ecu"]
      },
      {
        "id": "ASSET-FIRMWARE",
        "title": "Headlight ECU Firmware",
        "properties": ["integrity", "confidentiality"],
        "linkedDamageScenarioIds": ["DS-SAF-MALFUNCTION"],
        "componentIds": ["comp-afs-ecu"]
      }
    ],
    "damageScenarios": [
      {
        "id": "DS-SAF-BLIND",
        "title": "Driver or Road Users Blinded",
        "linkedAssetIds": ["ASSET-LIGHT-CTRL"]
      },
      {
        "id": "DS-SAF-GLARE",
        "title": "Oncoming Traffic Glare",
        "linkedAssetIds": ["ASSET-LIGHT-CTRL"]
      },
      {
        "id": "DS-PRIV-TRACK",
        "title": "Vehicle Tracking via Speed Data",
        "linkedAssetIds": ["ASSET-VEH-SPEED"]
      },
      {
        "id": "DS-PRIV-VEH-ID",
        "title": "Vehicle Identification Exposure",
        "linkedAssetIds": ["ASSET-DIAG-DATA"]
      },
      {
        "id": "DS-SAF-MALFUNCTION",
        "title": "Complete Headlight System Failure",
        "linkedAssetIds": ["ASSET-FIRMWARE"]
      }
    ],
    "threatScenarios": [
      {
        "id": "TS-CAN-SPOOF",
        "title": "CAN Message Injection Attack",
        "targetedAssetIds": ["ASSET-LIGHT-CTRL"],
        "compromisedProperties": ["integrity"]
      },
      {
        "id": "TS-DIAG-EXPLOIT",
        "title": "UDS Diagnostic Service Exploitation",
        "targetedAssetIds": ["ASSET-DIAG-DATA", "ASSET-FIRMWARE"],
        "compromisedProperties": ["confidentiality", "integrity"]
      },
      {
        "id": "TS-SPEED-SNIFF",
        "title": "Vehicle Speed Data Interception",
        "targetedAssetIds": ["ASSET-VEH-SPEED"],
        "compromisedProperties": ["confidentiality"]
      },
      {
        "id": "TS-FW-TAMPER",
        "title": "Firmware Modification Attack",
        "targetedAssetIds": ["ASSET-FIRMWARE"],
        "compromisedProperties": ["integrity"]
      }
    ],
    "attackSteps": [
      {
        "id": "AS-CAN-01",
        "title": "Gain physical access to vehicle interior or OBD-II port"
      },
      {
        "id": "AS-CAN-02",
        "title": "Connect to body CAN network via OBD-II or exposed wiring harness"
      },
      {
        "id": "AS-CAN-03",
        "title": "Identify headlight ECU CAN message IDs by sniffing network traffic"
      },
      {
        "id": "AS-CAN-04",
        "title": "Inject malicious CAN messages to manipulate headlight beam behavior"
      },
      {
        "id": "AS-DIAG-01",
        "title": "Access OBD-II diagnostic connector"
      },
      {
        "id": "AS-DIAG-02",
        "title": "Establish UDS diagnostic session with AFS ECU via gateway"
      },
      {
        "id": "AS-DIAG-03",
        "title": "Read diagnostic data including vehicle identification information"
      },
      {
        "id": "AS-FW-01",
        "title": "Establish extended or programming UDS diagnostic session"
      },
      {
        "id": "AS-FW-02",
        "title": "Exploit firmware update service to bypass integrity checks"
      },
      {
        "id": "AS-FW-03",
        "title": "Upload and execute malicious firmware payload on AFS ECU"
      },
      {
        "id": "AS-TRACK-01",
        "title": "Install passive CAN monitoring device on body network"
      },
      {
        "id": "AS-TRACK-02",
        "title": "Capture and decode vehicle speed data from CAN traffic"
      },
      {
        "id": "AS-TRACK-03",
        "title": "Correlate speed patterns with timestamps to build movement profile"
      }
    ],
    "attackPaths": [
