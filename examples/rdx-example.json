  "riskSet": {
    "itemDefinition": {
      "id": "ITEM-001",
      "title": "Connected Gateway ECU",
      "boundary": "Gateway ECU responsible for in-vehicle networks, OTA, and diagnostics",
      "functions": [
        "Routing",
        "Firewall",
        "OTA update",
        "Diagnostics"
      ],
      "architecture": "Tri-core MCU, AutoSAR, 2x CAN, 1x LIN, 1x Ethernet, WiFi/Cellular external link",
      "interfaces": [
        "CAN0",
        "CAN1",
        "ETH0",
        "DoIP",
        "UDS",
        "Cellular"
      ],
      "environment": "Series vehicle, US/EU, 2026 launch",
      "assumptions": [
        "Root-of-trust present",
        "Secure boot enabled"
      ],
      "countryOfOrigin": "DE"
    },
    "assets": [
      {
        "id": "ASSET-PII",
        "title": "Owner PII in Telematics",
        "properties": [
          "confidentiality"
        ],
        "linkedDamageScenarioIds": [
          "DS-PRIV-1"
        ]
      },
      {
        "id": "ASSET-BRK",
        "title": "Brake Control Data",
        "properties": [
          "integrity",
          "availability"
        ],
        "linkedDamageScenarioIds": [
          "DS-SAF-1"
        ]
      }
    ],
    "damageScenarios": [
      {
        "id": "DS-PRIV-1",
        "title": "Privacy harm via data exfiltration",
        "description": "Customer data disclosure"
      },
      {
        "id": "DS-SAF-1",
        "title": "Safety hazard via brake message spoofing",
        "description": "Potential loss of braking"
      }
    ],
    "threatScenarios": [
      {
        "id": "TS-1",
        "title": "Exploit exposed DoIP service",
        "targetedAssetIds": [
          "ASSET-BRK"
        ],
        "compromisedProperties": [
          "integrity"
        ],
        "cause": "Auth bypass on UDS over DoIP"
      },
      {
        "id": "TS-2",
        "title": "Exfiltrate PII via compromised telematics",
        "targetedAssetIds": [
          "ASSET-PII"
        ],
        "compromisedProperties": [
          "confidentiality"
        ],
        "cause": "Weak access control on backend API"
      }
    ],
    "attackSteps": [
      {
        "id": "AS-001",
        "title": "Scan DoIP services",
        "description": "Network scan to identify exposed DoIP endpoints on the vehicle",
        "attackFeasibilityRatingIds": ["AFR-AS-001"],
        "controlIds": ["CTRL-NET-MON"],
        "references": ["https://example.com/doip-security"]
      },
      {
        "id": "AS-002", 
        "title": "Exploit vulnerability",
        "description": "Exploit authentication bypass vulnerability in UDS over DoIP",
        "attackFeasibilityRatingIds": ["AFR-AS-002"],
        "controlIds": ["CTRL-VULN-PATCH"],
        "references": ["https://example.com/uds-vulns"]
      },
      {
        "id": "AS-003",
        "title": "Pivot to CAN network",
        "description": "Gain access to internal CAN bus from compromised DoIP service",
        "attackFeasibilityRatingIds": ["AFR-AS-003"],
        "controlIds": ["CTRL-NET-SEG"]
      },
      {
        "id": "AS-004",
        "title": "Inject malicious CAN frames",
        "description": "Send spoofed brake control messages on CAN bus",
        "attackFeasibilityRatingIds": ["AFR-AS-004"],
        "controlIds": ["CTRL-MSG-1"]
      }
    ],
    "attackPaths": [
      {
        "id": "AP-1",
        "title": "Compromise service -> send spoofed CAN",
        "threatScenarioId": "TS-1",
        "stepIds": ["AS-001", "AS-002", "AS-003", "AS-004"]
