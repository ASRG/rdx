        "targetedAssetIds": [
          "ASSET-PII"
        ],
        "compromisedProperties": [
          "confidentiality"
        ],
        "cause": "Weak access control on backend API"
      }
    ],
    "attackSteps": [
      {
        "id": "AS-001",
        "title": "Scan DoIP services",
