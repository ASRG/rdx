        "catalog": "OEM-SEC-CTRL",
        "controlId": "API-AUTHZ-01",
        "implementationStatus": "implemented"
      },
      {
        "id": "CTRL-OTA-SIG",
        "title": "Firmware signature verification for OTA updates",
        "catalog": "OEM-SEC-CTRL",
        "controlId": "OTA-SIG-01",
        "implementationStatus": "planned"
      },
      {
        "id": "CTRL-OTA-INFRA",
        "title": "Hardened OTA update server infrastructure",
        "catalog": "OEM-SEC-CTRL",
        "controlId": "OTA-INFRA-01",
        "implementationStatus": "planned"
      }
    ],
    "riskTreatmentDecisions": [
      {
        "id": "RTD-TS-1",
        "riskValueId": "RV-TS-1",
        "decision": "treat",
        "controls": [
          "CTRL-MSG-AUTH"
        ],
        "justification": "Risk band High maps to required treatment 'treat' per RTM-OEM-001. Implementing CAN MAC reduces spoofing feasibility."
      },
      {
        "id": "RTD-TS-2",
        "riskValueId": "RV-TS-2",
        "decision": "accept",
        "controls": [],
        "justification": "Risk band Low maps to required treatment 'accept' per RTM-OEM-001. Backend authorization controls already in place as compensating measure."
      },
      {
        "id": "RTD-TS-3",
        "riskValueId": "RV-TS-3",
        "decision": "avoid",
        "controls": [
          "CTRL-OTA-SIG",
          "CTRL-OTA-INFRA"
        ],
        "justification": "Risk band Very High maps to required treatment 'avoid' per RTM-OEM-001. Architecture redesign to enforce code signing and harden OTA infrastructure is required. Escalation submitted to CISO."
      }
    ],
